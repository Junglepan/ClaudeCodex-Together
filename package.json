{
  "name": "cc-steward",
  "type": "module",
  "version": "1.3.0",
  "description": "cc-steward — 本地 Claude Code / Codex CLI 配置管家",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -n \"frontend,electron\" -c \"green,blue\" \"npm run dev:frontend\" \"npm run dev:electron\"",
    "dev:frontend": "vite",
    "dev:electron": "wait-on http://127.0.0.1:5174 && electron dist-electron/main.js",
    "build": "tsc && vite build && electron-builder",
    "build:frontend": "vite build",
    "build:electron": "tsc -p electron/tsconfig.json && node -e \"require('fs').writeFileSync('dist-electron/package.json', JSON.stringify({type:'commonjs'}))\"",
    "check:file-assets": "node scripts/assert-file-url-assets.mjs",
    "test:backend": "tsx --test electron/backend/*.test.ts",
    "preview": "vite preview",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "smol-toml": "^1.6.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.14",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "playwright": "^1.59.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vite-plugin-electron": "^0.28.8",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.cc-steward.app",
    "productName": "cc-steward",
    "directories": {
      "output": "dist-app"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "!dist-electron/**/*.test.js",
      "assets/**/*"
    ],
    "mac": {
      "icon": "assets/icon.icns"
    },
    "win": {
      "icon": "assets/icon.ico"
    },
    "linux": {
      "icon": "assets/icon.png"
    }
  }
}
